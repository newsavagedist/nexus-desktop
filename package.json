{
  "name": "nexus-desktop",
  "version": "1.0.18",
  "description": "DaazNexus Desktop — Electron client",
  "desktopName": "com.daazlabs.DaazNexus",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev:renderer": "npm --prefix src/renderer run dev",
    "dev:electron": "npm run build:main && npx electron . --dev --no-sandbox --disable-software-rasterizer --disable-gpu-compositing",
    "dev": "concurrently -k \"npm run dev:renderer\" \"sleep 2 && npm run dev:electron\"",
    "build:renderer": "npm --prefix src/renderer run build",
    "build:main": "tsc -p tsconfig.electron.json",
    "start": "npm run build:main && npx electron . --no-sandbox --disable-software-rasterizer --disable-gpu-compositing",
    "start:dev": "npm run build:main && npx electron . --dev --no-sandbox --disable-software-rasterizer --disable-gpu-compositing",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "execa": "^9.5.2",
    "minimatch": "^10.2.5",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "keywords": [],
  "author": {
    "name": "DaazLabs",
    "email": "dev@daazlabs.com"
  },
  "homepage": "https://chat.daazlabs.com",
  "license": "ISC",
  "type": "module"
}
